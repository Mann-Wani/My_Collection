                      ) OBJECT(.\Objects\block_transfer.obj) EP

LOC  OBJ            LINE     SOURCE

0000                   1     ORG 0000H
                       2     
0000 7830              3         MOV R0, #30H      ; Pointer to Array 1
0002 7940              4         MOV R1, #40H      ; Pointer to Array 2
0004 7A03              5         MOV R2, #03H       ; Number of bytes to exchange
                       6     
0006                   7     EXCHANGE:
0006 E6                8         MOV A, @R0        ; Read element from Array 1
