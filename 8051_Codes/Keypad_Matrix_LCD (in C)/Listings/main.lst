  38           void lcd_init()    //Function to prepare the LCD  and get it ready
  39          {
  40   1          lcd_cmd(0x38);  // for using 2 lines and 5X7 matrix of LCD
  41   1          msdelay(10);
  42   1          lcd_cmd(0x0F);  // turn display ON, cursor blinking
  43   1          msdelay(10);
  44   1          lcd_cmd(0x01);  //clear screen
  45   1          msdelay(10);
