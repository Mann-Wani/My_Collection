  14          void msdelay(unsigned int time)  // Function for creating delay in milliseconds.
  15          {
  16   1          unsigned i,j ;
  17   1          for(i=0;i<time;i++)    
  18   1          for(j=0;j<1275;j++);
  19   1      }
  20          void lcd_cmd(unsigned char command)  //Function to send command instruction to LCD
  21          {
  22   1          display_port = command;
  23   1          rs= 0;
  24   1          rw=0;
  25   1          e=1;
  26   1          msdelay(1);
  27   1          e=0;
